{
  "family": "credit-scoring-task",
  "containerDefinitions": [
    {
      "name": "credit-scoring-task",
      "image": "REPLACE_IMAGE_URI",
      "cpu": 1024,
      "memory": 1024,
      "portMappings": [
        {
          "name": "credit-scoring-task-8000-tcp",
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp",
          "appProtocol": "http"
        },
        {
          "name": "credit-scoring-task-8501-tcp",
          "containerPort": 8501,
          "hostPort": 8501,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/credit-scoring-task",
          "awslogs-create-group": "true",
          "awslogs-region": "eu-west-3",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "systemControls": []
    }
  ],
  "executionRoleArn": "arn:aws:iam::756916139370:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}